# Circuit environment variables
# Copy to .env and fill in your values

# OpenRouter API key (required unless set in .circuit file)
OPENROUTER_API_KEY=sk-or-...

# Optional overrides (these are lower priority than .circuit file defines)
# CIRCUIT_PROMPT_ENGINEER_MODEL=anthropic/claude-haiku-4-5
# CIRCUIT_RUN_BIN=claude --dangerously-skip-permissions
# CIRCUIT_EVAL_BIN=claude --dangerously-skip-permissions
# CIRCUIT_DIR=.
# CIRCUIT_LOG_DIR=.circuit-runs
# CIRCUIT_TIMEOUT=0

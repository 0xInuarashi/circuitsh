# Parameter Golf — OpenAI model compression competition
# Goal: Train the lowest BPB language model within 16MB / 10min on 8xH100
# https://github.com/openai/parameter-golf

PROVIDER Openrouter
# API_KEY ${OPENROUTER_API_KEY}

API_KEY sk-hypercanvas-ea5ae94a72a89e837e07a226742cfb68cc67d2c327570c24
API_URL https://claude-oauth-api-0xtayzon-production.up.railway.app/api/v1

PROMPT_ENGINEER_MODEL anthropic/claude-sonnet-4-6
ALIAS claude "claude --dangerously-skip-permissions"
RUN_BIN claude
EVAL_BIN claude
DIR ~/parameter-golf
CHECKPOINT on
TIMEOUT 900

CIRCUIT_CONTEXT "runpod API key is ${RUNPOD_API_KEY}"


CIRCUIT Parameter Golf:
  # Step 1: Clone repo and deep-study winning submissions
  RUN Clone https://github.com/openai/parameter-golf. \
    Read the README, baseline train_gpt.py, and every submission \
    in records/track_10min_16mb/ — especially the top 3. \
    Write a detailed analysis to analysis.md covering: \
    what architecture changes they made, what training tricks they use, \
    what quantization/compression approach gets them under 16MB, \
    and what the biggest BPB wins come from.

  # Step 2: Provision RunPod 8xH100 and set up environment
  RUN Provision a RunPod instance with 8x H100 SXM GPUs. \
    Use the RunPod API (or CLI) to create the pod. \
    Then SSH in and: clone parameter-golf, install dependencies, \
    download the dataset with python3 data/cached_challenge_fineweb.py \
    --variant sp1024 --train-shards 80. Verify all 8 GPUs are visible.
    ALLOW_REQUEST "a RunPod API key is required"
    ALLOW_REQUEST "SSH credentials or key are needed for the pod"
    # ALLOW_REQUEST "compute budget approval is needed"
    NOTIFY ./notify.sh
    REQUEST_TIMEOUT 600
  EVAL SSH into the RunPod instance and verify: \
    nvidia-smi shows 8x H100, the repo is cloned, \
    dependencies are installed, and data/datasets/fineweb10B_sp1024/ \
    contains the training shards.
    RETRY 20

  # Step 3: Run baseline to establish starting BPB
  RUN SSH into RunPod and run the unmodified baseline: \
    torchrun --standalone --nproc_per_node=8 train_gpt.py \
    Capture the full output log. Record the final val_bpb \
    and submission artifact size.
  EVAL Did training complete within 10 minutes? \
    What is the baseline val_bpb? It should be around 1.2244. \
    Save the log as baseline.log locally.
    RETRY 2

  # Step 4: Implement first round of optimizations
  RUN Based on analysis.md and the winning submissions, \
    create a modified train_gpt.py with the highest-impact changes. \
    Prioritize proven techniques from top submissions: \
    11-layer 512d architecture, XSA (exclusive self-attention), \
    EMA weight averaging, partial RoPE, optimized LR schedule. \
    Keep the code clean — artifact size (code + compressed weights) \
    must stay under 16MB. Push the modified script to RunPod via SCP.
  EVAL SSH into RunPod and run the modified training script. \
    Does it complete in under 10 minutes? \
    Is the artifact under 16MB? \
    Is val_bpb lower than the baseline (1.2244)?
    RETRY 5

  # Step 5: Optimize quantization and compression
  RUN The 16MB cap is code + compressed weights combined. \
    Experiment with better quantization (int6, GPTQ-lite) \
    and compression (LZMA/zstd instead of zlib) to free up \
    parameter budget. If we save bytes on compression, \
    we can afford a bigger model. Push changes to RunPod.
  EVAL Run training on RunPod. Is the compressed artifact smaller \
    than before? Did val_bpb improve or at least not regress? \
    Log the exact artifact size and BPB.
    RETRY 5

  # Step 6: Advanced techniques — push for leaderboard
  RUN Implement advanced optimizations: test-time training (TTT) \
    on validation chunks, LeakyReLU activations, parallel Muon optimizer, \
    SmearGate, BigramHash embeddings, or other novel approaches from \
    analysis.md. Focus on whatever has the most remaining BPB headroom. \
    Push to RunPod.
  EVAL Run 3 training runs with different seeds (42, 1337, 2025) on RunPod. \
    Report all 3 val_bpb scores and the average. \
    Is the average competitive with top leaderboard (below 1.12)?
    # ALLOW_REQUEST "additional compute budget approval needed"
    # NOTIFY ./notify.sh
    # REQUEST_TIMEOUT 600
    RETRY 5

  # Step 7: Prepare and submit
  RUN Prepare the submission package: \
    create records/track_10min_16mb/YYYY-MM-DD_OurSubmission/ \
    with README.md (methodology, results, run command), \
    submission.json (author, val_bpb, bytes_total, etc.), \
    the final train_gpt.py, and 3+ training logs. \
    Fork the repo and create a pull request.
    ALLOW_REQUEST "GitHub credentials are needed for the PR"
    ALLOW_REQUEST "author name and details are needed for submission.json"
    NOTIFY ./notify.sh
    REQUEST_TIMEOUT 600
  EVAL Verify the submission folder has all required files. \
    Verify submission.json values match actual training results. \
    Verify the PR is created and passes any CI checks.
    RETRY 3
